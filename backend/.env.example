# Anthropic API key used for AI field extraction
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# Model to use for extraction
ANTHROPIC_MODEL=claude-sonnet-4-6

# Server port
PORT=5000

# Allowed frontend origin (CORS)
CLIENT_ORIGIN=http://localhost:3000

# How many CSV rows to send to the AI per batch
AI_BATCH_SIZE=15

# Max retry attempts per failed batch
AI_MAX_RETRIES=2
